// rule 4
// return consern the type
// if value exposed, or by a variable
func example()
    return 10
    // or
    return a
end
// if the param
func example(a: int) // or (a)
    return a
end
// if the operation
func example(a, b)
    return a + b as float // default to flaot
end
// if the function call/structer/enum field
func example(s: Struct, e: Num)
    return s.field
    return e.variant
    return function_call()
end
// if known operation in if stmt
func example()
	let a = 10
    let b = 2

    if a > b then
    	return true
    end

    return 124
end
// if something or just empty return
func example(a, b)
    if a > b then
    	return true
    end

    return // bool
end
// rule 5
// enum, struct usage
struct Simple
    a: int
    b: str
end

let a = Simple.a // int
// in func call
return Simple.a

// rule 6
// genertic rule 
func example[A](a)
	return a as A
end

example(124) // will make genertic a int
// rule 7
// if float, number always consern as float
func example(a, b)
	if a > b then
		return 1.2
        else
        return 1 as float // automaticlly to flaot
	end
end
// rule 8
// if always return with no context just return what variable asks for, like if it ask for int return int like that
func example(a, b)
	if a > b then
		return
	end

    return
end

var a: int = example(1, 2)
// if:
var a: str = example(1, 2)
var b: int = example(1, 2)
// in ir:
func example_main(a, b)
	if a > b then
		return
	end

    return
end

func example_1(a, b): int
    example(a, b)

    return
end

func example_2(a, b): str
    example(a, b)

    return
end

var a: str = example_1(1, 2)
var b: int = example_2(1, 2)

// rule 9
// if the function calling it self, check the operation: 'if n < 2' return n means it's a int/float
func fib(n)
    if n < 2 then return n end
    return fib(n - 1) + fib(n - 2)
end
// rule 10
// if Shadowing return the variable that in the same scope
var a = 124

func example()
    var a = '!'

    return a // will be char as an return type
end


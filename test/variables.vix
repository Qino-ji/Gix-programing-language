const MAX_ITER:   int    = 1000
const MIN_ITER:   int    = 1
const BUF_SIZE:   int    = 4096
const PAGE_SIZE:  int    = 4096
const WORD_BITS:  int    = 32
const BYTE_BITS:  int    = 8
const NIBBLE:     int    = 4
const MASK_8:     int    = 255
const MASK_16:    int    = 65535
const SHIFT_1:    int    = 2
const SHIFT_2:    int    = 4
const SHIFT_3:    int    = 8
const SHIFT_4:    int    = 16
const THRESHOLD:  int    = 50
const LIMIT:      int    = 100
const HALF:       int    = 50
const QUARTER:    int    = 25
const TRUE_FLAG:  bool   = true
const FALSE_FLAG: bool   = false
const ZERO_F:     float  = 0.0
const ONE_F:      float  = 1.0
const PI:         float  = 3.14159
const E:          float  = 2.71828
const LN2:        float  = 0.693
const SQRT2:      float  = 1.414
const EMPTY_STR:  string = ""
const SPACE:      string = " "
const NL:         string = "\n"
const NULL_CHAR:  char   = '\0'
const TAB_CHAR:   char   = '\t'
const I8_MIN:     int8   = -128
const I8_MAX:     int8   = 127
const I16_MIN:    int16  = -32768
const I16_MAX:    int16  = 32767
const I32_MIN:    int32  = -2147483648
const I32_MAX:    int32  = 2147483647
const I64_MAX:    int64  = 9223372036854775807
const F32_HALF:   float32 = 0.5
const F64_PI:     float64 = 3.141592653589793

const DERIVED_A:  int = MAX_ITER + MIN_ITER
const DERIVED_B:  int = BUF_SIZE * 2
const DERIVED_C:  int = MASK_8 & MASK_16
const DERIVED_D:  int = SHIFT_1 + SHIFT_2 + SHIFT_3 + SHIFT_4
const DERIVED_E:  int = THRESHOLD * 2 - QUARTER
const DERIVED_F:  int = 1 << NIBBLE
const DERIVED_G:  int = PAGE_SIZE / BYTE_BITS
const DERIVED_H:  bool = TRUE_FLAG and not FALSE_FLAG
const DERIVED_I:  int = (MASK_8 | SHIFT_4) ^ SHIFT_3

func abs(n: int): int
    if n < 0 then return -n end
    return n
end

func sign(n: int): int
    if n > 0 then return 1
    elif n < 0 then return -1
    else return 0
    end
end

func min2(a: int, b: int): int
    if a < b then return a end
    return b
end

func max2(a: int, b: int): int
    if a > b then return a end
    return b
end

func clamp(v: int, lo: int, hi: int): int
    if v < lo then return lo end
    if v > hi then return hi end
    return v
end

func in_range(v: int, lo: int, hi: int): bool
    return v >= lo and v <= hi
end

func is_even(n: int): bool
    return n % 2 == 0
end

func is_odd(n: int): bool
    return n % 2 != 0
end

func is_power_of_two(n: int): bool
    return n > 0 and (n & (n - 1)) == 0
end

func bit_count(n: int): int
    var cnt: int = 0
    var v:   int = n
    for i in 32 do
        if (v >> i) & 1 != 0 then
            cnt += 1
        end
    end
    return cnt
end

func swap_bits(n: int, i: int, j: int): int
    var bi: int = (n >> i) & 1
    var bj: int = (n >> j) & 1
    if bi != bj then
        n ^= (1 << i) | (1 << j)
    end
    return n
end

func rotate_left(n: int, bits: int): int
    return (n << bits) | (n >> (32 - bits))
end

func rotate_right(n: int, bits: int): int
    return (n >> bits) | (n << (32 - bits))
end

func sum3(a: int, b: int, c: int): int
    return a + b + c
end

func product3(a: int, b: int, c: int): int
    return a * b * c
end

func avg2(a: int, b: int): int
    return (a + b) / 2
end

func gcd(a: int, b: int): int
    var x: int = abs(a)
    var y: int = abs(b)
    for i in MAX_ITER do
        if y == 0 then return x end
        var tmp: int = y
        y = x % y
        x = tmp
    end
    return x
end

func lcm(a: int, b: int): int
    var g: int = gcd(a, b)
    if g == 0 then return 0 end
    return abs(a * b) / g
end

func factorial(n: int): int
    var result: int = 1
    for i in n do
        result *= i + 1
    end
    return result
end

func fib(n: int): int
    if n <= 0 then return 0 end
    if n == 1 then return 1 end
    var a: int = 0
    var b: int = 1
    for i in n - 1 do
        var tmp: int = a + b
        a = b
        b = tmp
    end
    return b
end

func is_prime(n: int): bool
    if n < 2 then return false end
    if n == 2 then return true end
    if is_even(n) then return false end
    for i in n do
        var d: int = i + 3
        if d * d > n then return true end
        if n % d == 0 then return false end
    end
    return true
end

func count_digits(n: int): int
    var cnt: int = 0
    var v: int   = abs(n)
    if v == 0 then return 1 end
    for i in 20 do
        if v == 0 then return cnt end
        v   /= 10
        cnt += 1
    end
    return cnt
end

func digit_sum(n: int): int
    var s: int = 0
    var v: int = abs(n)
    for i in 20 do
        if v == 0 then return s end
        s += v % 10
        v /= 10
    end
    return s
end

func reverse_bits(n: int): int
    var result: int = 0
    for i in 32 do
        result = (result << 1) | (n & 1)
        n >>= 1
    end
    return result
end

func next_pow2(n: int): int
    var v: int = n - 1
    v |= v >> 1
    v |= v >> 2
    v |= v >> 4
    v |= v >> 8
    v |= v >> 16
    return v + 1
end

func pack_bytes(a: int, b: int, c: int, d: int): int
    return (a & 0xFF)       |
           ((b & 0xFF) << 8)  |
           ((c & 0xFF) << 16) |
           ((d & 0xFF) << 24)
end

func unpack_byte0(packed: int): int  return packed & 0xFF end
func unpack_byte1(packed: int): int  return (packed >> 8)  & 0xFF end
func unpack_byte2(packed: int): int  return (packed >> 16) & 0xFF end
func unpack_byte3(packed: int): int  return (packed >> 24) & 0xFF end

func lerp(a: int, b: int, t_num: int, t_den: int): int
    return a + (b - a) * t_num / t_den
end

func dot2(ax: int, ay: int, bx: int, by: int): int
    return ax * bx + ay * by
end

func cross2(ax: int, ay: int, bx: int, by: int): int
    return ax * by - ay * bx
end

func manhattan(ax: int, ay: int, bx: int, by: int): int
    return abs(ax - bx) + abs(ay - by)
end

func chebyshev(ax: int, ay: int, bx: int, by: int): int
    return max2(abs(ax - bx), abs(ay - by))
end

func in_rect(px: int, py: int, rx: int, ry: int, rw: int, rh: int): bool
    return px >= rx and px < rx + rw and py >= ry and py < ry + rh
end

func saturate_add(a: int, b: int, max_val: int): int
    var s: int = a + b
    if s > max_val then return max_val end
    return s
end

func saturate_sub(a: int, b: int, min_val: int): int
    var s: int = a - b
    if s < min_val then return min_val end
    return s
end

func map_range(v: int, in_lo: int, in_hi: int, out_lo: int, out_hi: int): int
    if in_hi == in_lo then return out_lo end
    return out_lo + (v - in_lo) * (out_hi - out_lo) / (in_hi - in_lo)
end

func hash_int(n: int): int
    var h: int = n
    h ^= h >> 16
    h *= 0x45d9f3b
    h ^= h >> 16
    return h
end

func mix(a: int, b: int, c: int): int
    var x: int = a
    var y: int = b
    var z: int = c
    x -= y  x -= z  x ^= z >> 13
    y -= z  y -= x  y ^= x << 8
    z -= x  z -= y  z ^= y >> 13
    return z
end

func bool_to_int(v: bool): int
    if v then return 1 end
    return 0
end

func int_to_bool(v: int): bool
    return v != 0
end

func negate(v: int): int     return -v end
func complement(v: int): int return v ^ G_WORD_MASK end

func all_set(a: bool, b: bool, c: bool, d: bool): bool
    return a and b and c and d
end

func any_set(a: bool, b: bool, c: bool, d: bool): bool
    return a or b or c or d
end

func none_set(a: bool, b: bool, c: bool, d: bool): bool
    return not a and not b and not c and not d
end

func exactly_one(a: bool, b: bool, c: bool, d: bool): bool
    var cnt: int = bool_to_int(a) + bool_to_int(b) + bool_to_int(c) + bool_to_int(d)
    return cnt == 1
end


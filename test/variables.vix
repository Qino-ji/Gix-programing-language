class Vec2(x: int, y: int)
    var _x: int
    var _y: int

    func get_x(): int   return _x end
    func get_y(): int   return _y end
    func is_zero(): bool return _x == 0 and _y == 0 end
    func len_sq(): int  return _x * _x + _y * _y end

    @operation("+")
    func add(other: Vec2): Vec2
        var rx: int = _x + other.get_x()
        var ry: int = _y + other.get_y()
        return Vec2(x: rx, y: ry)
    end

    @operation("-")
    func sub(other: Vec2): Vec2
        var rx: int = _x - other.get_x()
        var ry: int = _y - other.get_y()
        return Vec2(x: rx, y: ry)
    end

    @operation("==")
    func eq(other: Vec2): bool
        return _x == other.get_x() and _y == other.get_y()
    end

    @operation("!=")
    func neq(other: Vec2): bool
        return _x != other.get_x() or _y != other.get_y()
    end
end

class Counter(start: int, step: int)
    var count: int
    var total: int

    func get(): int         return count end
    func get_total(): int   return total end
    func is_done(): bool    return count >= start end
    func at_zero(): bool    return count == 0 end
    func overflowed(): bool return count > start end

    func tick(): int
        count += step
        total += count
        return count
    end

    func reset(): int
        var old: int = count
        count = 0
        total = 0
        return old
    end

    func clamp_to(hi: int): int
        if count > hi then
            count = hi
        end
        return count
    end
end

class Accumulator(init: int)
    var value: int
    var ops:   int

    func get(): int      return value end
    func op_count(): int return ops end
    func is_neg(): bool  return value < 0 end
    func is_pos(): bool  return value > 0 end
    func is_zero(): bool return value == 0 end

    @operation("+")
    func add(n: int): int
        value += n
        ops   += 1
        return value
    end

    @operation("-")
    func sub(n: int): int
        value -= n
        ops   += 1
        return value
    end

    @operation("*")
    func mul(n: int): int
        value *= n
        ops   += 1
        return value
    end

    @operation("/")
    func div(n: int): int
        if n != 0 then
            value /= n
        end
        ops += 1
        return value
    end

    @operation(%)
    func rem(n: int): int
        if n != 0 then
            value %= n
        end
        ops += 1
        return value
    end

    @operation(&)
    func band(n: int): int
        value &= n
        ops   += 1
        return value
    end

    @operation(|)
    func bor(n: int): int
        value |= n
        ops   += 1
        return value
    end

    @operation(^)
    func bxor(n: int): int
        value ^= n
        ops   += 1
        return value
    end
end

class RangeChecker(lo: int, hi: int)
    var _lo: int
    var _hi: int
    var hits: int
    var misses: int

    func in_range(v: int): bool
        if v >= _lo and v <= _hi then
            hits += 1
            return true
        else
            misses += 1
            return false
        end
    end

    func clamp(v: int): int
        if v < _lo then return _lo end
        if v > _hi then return _hi end
        return v
    end

    func span(): int  return _hi - _lo end
    func mid(): int   return (_lo + _hi) / 2 end
    func empty(): bool return _lo >= _hi end
end

class BitField(width: int)
    var data:  int
    var _mask: int

    func get(): int       return data end
    func set(v: int): int data = v & _mask  return data end
    func clear(): int     data = 0          return data end

    func bit_set(pos: int): bool   return (data >> pos) & 1 != 0 end
    func bit_clear(pos: int): bool return (data >> pos) & 1 == 0 end

    func set_bit(pos: int): int
        data |= 1 << pos
        return data
    end

    func clr_bit(pos: int): int
        data &= ~(1 << pos)
        return data
    end

    func tog_bit(pos: int): int
        data ^= 1 << pos
        return data
    end

    func popcount(): int
        var n:   int = data
        var cnt: int = 0
        for i in width do
            if (n >> i) & 1 != 0 then
                cnt += 1
            end
        end
        return cnt
    end
end


var cx1: int  = abs(vi1) + abs(vi2)
var cx2: int  = max2(abs(vi1), abs(vi2))
var cx3: int  = clamp(vi1 + vi2, 0, LIMIT)
var cx4: bool = is_prime(fib(7))
var cx5: int  = gcd(factorial(4), factorial(6))
var cx6: int  = hash_int(mix(vi1, vi2, vi3))
var cx7: int  = pack_bytes(unpack_byte0(vi1), unpack_byte1(vi1), vi2 & 0xFF, vi3 & 0xFF)
var cx8: bool = in_range(clamp(vi1, 0, 100), 0, THRESHOLD)
var cx9: int  = map_range(clamp(vi1, 0, 100), 0, 100, 0, 255)
var cx10: int = lerp(0, 100, 1, 3)
var cx11: bool = all_set(vbl1, vbl2, vbl6, vbl9)
var cx12: bool = any_set(vbl1, vbl7, is_prime(vi1), is_even(vi2))
var cx13: int  = saturate_add(vi1, vi2, MAX_ITER)
var cx14: int  = saturate_sub(vi1, vi2, 0)
var cx15: int  = bit_count(reverse_bits(vi1)) 

let li1:  int     = 0
let li2:  int     = -1
let li3:  int     = 2147483647
let li4:  int8    = 127
let li5:  int16   = -32768
let li6:  int32   = 99999
let li7:  int64   = 9999999999
let lf1:  float   = 3.14
let lf2:  float32 = 0.5
let lf3:  float64 = 2.718281828
let lb1:  bool    = true
let lb2:  bool    = false
let lc1:  char    = 'x'
let ls1:  string  = "immutable"
let ls2:  string  = ""

let la1: int  = vi1 + vi2
let la2: int  = vi1 * vi3 - vi4
let la3: int  = abs(vi2)
let la4: int  = max2(vi1, vi3)
let la5: int  = clamp(vi1, 0, 100)
let la6: bool = vi1 > vi2 and vi3 != 0
let la7: bool = is_prime(vi3)
let la8: bool = is_even(vi1) or is_odd(vi2)
let la9: int  = fib(8)
let la10: int = gcd(vi1 + vi2, vi3)
let la11: int = hash_int(vi1 ^ vi2)
let la12: int = sum3(vi1, vi2, vi3) * avg2(vi4, vi5)
let la13: bool = in_range(vi1, li1, li3)
let la14: int  = bit_count(vi1 | vi2 | vi3)
let la15: int  = rotate_left(vi1, SHIFT_1)

let lmc1: int  = ctr1.get()
let lmc2: bool = ctr1.is_done()
let lmc3: int  = acc1.op_count()
let lmc4: bool = rng1.in_range(vi1)
let lmc5: int  = rng2.span()
let lmc6: bool = bf1.bit_set(0)
let lmc7: int  = bf2.popcount()

 
 
 

const C_I:    int     = 42
const C_I8:   int8    = 100
const C_I16:  int16   = 1000
const C_I32:  int32   = 100000
const C_I64:  int64   = 10000000000
const C_F:    float   = 1.0
const C_F32:  float32 = 0.25
const C_F64:  float64 = 1.4142135623
const C_B1:   bool    = true
const C_B2:   bool    = false
const C_CH:   char    = 'C'
const C_STR:  string  = "const"

const C_ADD:  int = 10 + 20
const C_SUB:  int = 100 - 37
const C_MUL:  int = 6 * 7
const C_DIV:  int = 144 / 12
const C_MOD:  int = 17 % 5
const C_AND:  int = 0xFF & 0x0F
const C_OR:   int = 0xF0 | 0x0F
const C_XOR:  int = 0xAA ^ 0x55
const C_SHL:  int = 1 << 10
const C_SHR:  int = 1024 >> 3
const C_NEG:  int = -C_ADD
const C_NOT:  bool = not C_B1
const C_BOOL: bool = C_B1 and not C_B2
const C_CMP:  bool = C_I > C_I8
const C_MIX:  int  = (C_AND | C_SHL) ^ C_XOR
const C_CHAIN:int  = C_ADD * C_SUB - C_MUL + C_DIV % C_MOD

global GX_I:    int     = 1
global GX_I8:   int8    = 2
global GX_I16:  int16   = 3
global GX_I32:  int32   = 4
global GX_I64:  int64   = 5
global GX_F:    float   = 1.1
global GX_F32:  float32 = 2.2
global GX_F64:  float64 = 3.3
global GX_B1:   bool    = true
global GX_B2:   bool    = false
global GX_CH:   char    = 'G'
global GX_STR:  string  = "global_x"

global GX_A1:   int  = 10 + 20
global GX_A2:   int  = 100 - 1
global GX_A3:   int  = 3 * 3
global GX_A4:   int  = 100 / 5
global GX_A5:   int  = 99 % 7
global GX_A6:   int  = 1 << 4
global GX_A7:   int  = 64 >> 2
global GX_A8:   int  = 0xAB & 0x0F
global GX_A9:   int  = 0xA0 | 0x0B
global GX_A10:  int  = 0xFF ^ 0xF0
global GX_BOOL: bool = true and not false
global GX_CMP:  bool = 10 > 5 and 3 != 0

 
 
 

var ax: int = 0

ax = 1
ax = -1
ax = vi1
ax = vi1 + vi2
ax = vi1 * vi3 - vi4
ax = (vi1 + vi2) * (vi3 - vi4)
ax = vi1 & vi2
ax = vi1 | vi3
ax = vi1 ^ vi2
ax = vi1 << 2
ax = vi3 >> 1
ax = abs(vi2)
ax = max2(vi1, vi3)
ax = clamp(vi1, 0, 100)
ax = gcd(vi1, vi2)
ax = hash_int(vi1)
ax = ctr1.get()
ax = acc1.op_count()
ax = rng1.span()
ax = bf1.get()
ax = mix(vi1, vi2, vi3)
ax = pack_bytes(vi1, vi2, vi3, vi4)
ax = map_range(vi1, 0, 100, 0, 255)

ax += 1
ax += vi1
ax += vi1 + vi2
ax += vi1 * vi2
ax += abs(vi1)
ax += ctr1.get()
ax += max2(vi1, vi2) * min2(vi3, vi4)

ax -= 1
ax -= vi1
ax -= vi1 - vi2
ax -= abs(vi3)
ax -= ctr2.get()

ax *= 2
ax *= vi1
ax *= vi1 + 1
ax *= max2(vi1, 1)

ax /= 2
ax /= vi1 + 1
ax /= max2(vi1, 1)

ax %= 7
ax %= vi2 + 1
ax %= max2(vi3, 1)

ax &= 0xFF
ax &= vi1
ax &= vi1 | vi2
ax &= MASK_8

ax |= 1
ax |= vi1
ax |= vi1 & vi2
ax |= G_BITS

ax ^= 1
ax ^= vi1
ax ^= vi1 + vi2
ax ^= hash_int(vi1)

ax <<= 1
ax <<= 2
ax <<= SHIFT_1
ax <<= vi1 & 31

ax >>= 1
ax >>= 2
ax >>= SHIFT_1
ax >>= vi1 & 31

var m_a:    int    = vi1 + C_ADD
var m_b:    int    = vi2 * GX_A3
var m_c:    bool   = m_a > m_b
var m_d:    int    = clamp(m_a, 0, MAX_ITER)
let m_e:    int    = gcd(m_a, m_b)
const M_F:  int    = C_ADD + C_MUL
global M_G: int    = 0
var m_h:    bool   = is_prime(m_d)
var m_i:    int    = bool_to_int(m_h) * m_d
var m_j:    int    = hash_int(mix(m_a, m_b, m_e))

var loop_acc:  int = 0
var loop_bits: int = 0
var loop_min:  int = MAX_ITER
var loop_max:  int = 0

for i in MAX_ITER do
    var cur: int = hash_int(i) & MASK_8
    loop_acc  += cur
    loop_bits |= cur
    if cur < loop_min then loop_min = cur end
    if cur > loop_max then loop_max = cur end
end

var range_res: int = 0
for i in 32 do
    if is_prime(i) then
        range_res += i
    elif is_even(i) then
        range_res |= (1 << i) & MASK_16
    else
        range_res ^= i
    end
end

var ctr_a: Counter     = Counter(start: 16, step: 1)
var ctr_b: Counter     = Counter(start: 8,  step: 2)
var acc_m: Accumulator = Accumulator(init: loop_acc)
var rng_m: RangeChecker = RangeChecker(lo: loop_min, hi: loop_max)
var bf_m:  BitField    = BitField(width: 16)

var step_res: int = 0

for i in 16 do
    ctr_a.tick()
    ctr_b.tick()
    acc_m.add(i)
    acc_m.mul(2)
    acc_m.div(3)
    bf_m.set_bit(i & 15)
    step_res += rng_m.clamp(ctr_a.get())
end

var final_bits: int = bf_m.get()
var final_cnt:  int = bf_m.popcount()
var final_acc:  int = acc_m.get()

var nested: int = 0
if m_c and not ctr_a.is_done() then
    nested = clamp(final_acc, 0, MAX_ITER)
elif m_a > 0 and m_b > 0 then
    nested = gcd(m_a, m_b)
elif m_a == m_b or m_e == 0 then
    nested = abs(m_a - m_b)
else
    nested = hash_int(m_j)
end

let final_verdict: bool =
    in_range(nested,    0, MAX_ITER) and
    in_range(loop_acc,  0, MAX_ITER) and
    in_range(range_res, 0, MAX_ITER) and
    final_cnt >= 0 and
    not none_set(vbl1, vbl6, m_c, m_h)
func raw_check(ptr: *int): int
    if ptr == 0 then
        return -1
    end

    return 1
end

func double_ptr_check(ptr: **int): int
    if ptr == 0 then
        return -1
    elif ptr != 0 then
        return 1
    else
        return 0
    end
end

func max[T](a: T, b: T): T
    if a > b then
        return a
    else
        return b
    end
end

func min[T](a: T, b: T): T
    if a < b then
        return a
    else
        return b
    end
end

func is_between[T](val: T, lo: T, hi: T): bool
    if val >= lo and val <= hi then
        return true
    else
        return false
    end
end



class Counter(start: int)
    var count: int

    func get(): int
        return count
    end

    func is_done(): bool
        return count >= start
    end
end

 
class Counter(start: int)
    var count: int

    func get(): int
        return count
    end

    func is_done(): bool
        return count >= start
    end
end

class Obj()
    var value: int
    var active: bool
    var done: bool
    var valid: bool

    func is_ready(): bool  return active end
    func get_value(): int  return value end
    func is_valid(): bool  return valid end
    func is_active(): bool return active end
    func is_done(): bool   return done end
    func check(): bool     return valid end

    func compare(b: int): int
        if value > b then
            return 1
        elif value == b then
            return 0
        else
            return -1
        end
    end
end

class List()
    var size: int

    func len(): int
        return size
    end
end



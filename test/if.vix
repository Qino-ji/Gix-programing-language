func get_value(): int             return 42 end

func check(a: int, b: int): bool
    if a > b then
        return true
    else
        return false
    end
end

func is_valid(v: int): bool
    if v > 0 then
        return true
    else
        return false
    end
end

func is_empty(s: string): bool
    if s == "" then
        return true
    else
        return false
    end
end





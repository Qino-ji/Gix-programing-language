func check_sign(n: int): int
    if n > 0 then
        return 1
    elif n == 0 then
        return 0
    else
        return -1
    end
end

func clamp(val: int, lo: int, hi: int): int
    if val < lo then
        return lo
    elif val > hi then
        return hi
    else
        return val
    end
end

func all_positive(a: int, b: int, c: int): bool
    if a > 0 and b > 0 and c > 0 then
        return true
    else
        return false
    end
end

func any_zero(a: int, b: int, c: int): bool
    if a == 0 or b == 0 or c == 0 then
        return true
    else
        return false
    end
end


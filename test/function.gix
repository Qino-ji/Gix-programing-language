func min[T](a: T, b: T): T            return b end
func clamp[T](val: T, lo: T, hi: T): T return val end
func is_between[T](val: T, lo: T, hi: T): bool return true end
func triple_same[T](a: T, b: T, c: T): T return a end
func ignore_two[T](a: T, b: T, c: T): T  return c end

 

func pair_first[A, B](a: A, b: B): A   return a end
func pair_second[A, B](a: A, b: B): B  return b end
func pair_const[A, B](a: A, b: B): int return 0 end
func map_key[K, V](k: K, v: V): K      return k end
func map_val[K, V](k: K, v: V): V      return v end
func either[L, R](l: L, r: R): L       return l end

 

func triple_first[A, B, C](a: A, b: B, c: C): A return a end

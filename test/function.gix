func add(a: int, b: int): int       return a + b end
func sub(a: int, b: int): int       return a - b end
func mul(a: int, b: int): int       return a * b end
func div2(a: int, b: int): int      return a / b end
func mod2(a: int, b: int): int      return a % b end
func band(a: int, b: int): int      return a & b end
func bor(a: int, b: int): int       return a | b end
func bxor(a: int, b: int): int      return a ^ b end
func shl(a: int, b: int): int       return a << b end
func shr(a: int, b: int): int       return a >> b end
func eq(a: int, b: int): bool       return a == b end
func ne(a: int, b: int): bool       return a != b end
func lt(a: int, b: int): bool       return a < b end
func gt(a: int, b: int): bool       return a > b end
func le(a: int, b: int): bool       return a <= b end
func ge(a: int, b: int): bool       return a >= b end
func land(a: bool, b: bool): bool   return a and b end
func lor(a: bool, b: bool): bool    return a or b end
func lnot(a: bool): bool            return not a end


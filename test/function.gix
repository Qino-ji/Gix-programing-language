func make_point(x: int, y: int): Point
    return Point { x: x, y: y }
end

func make_node(l: int, r: int): Node
    return Node { left: l, right: r }
end

func make_result(ok: bool, code: int): StatusResult
    return StatusResult { ok: ok, code: code }
end

func make_rect(x: int, y: int, w: int, h: int): Rect
    return Rect { x: x, y: y, width: w, height: h }
end

func make_color(r: int, g: int, b: int): Color
    return Color { r: r, g: g, b: b }
end

func make_range(lo: int, hi: int): Range
    return Range { lo: lo, hi: hi }
end

func make_pair(f: int, s: int): Pair
    return Pair { first: f, second: s }
end

func make_triple(a: int, b: int, c: int): Triple
    return Triple { a: a, b: b, c: c }
end

func make_named(n: str, v: int): Named
    return Named { name: n, value: v }
end

func make_header(id: int, sz: int, f: bool): Header
    return Header { id: id, size: sz, flag: f }
end

 


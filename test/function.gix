end

 

func body_let(): int
    let r: int = compute(a: 10, b: 20)
    return r
end

func body_let_chain(): int
    let a: int = get_a()
    let b: int = get_b()
    let r: int = compute(a: a, b: b)
    return r
end

func body_vars(): int
    var lx: int = 10
    var ly: int = 20
    var lz: int = 30
    return lz
end

func body_assigns(): int
    var lx: int = 0
    lx += 1
    lx += 2
    lx -= 1
    lx *= 2
    lx /= 2
    lx %= 3
    lx &= 255
    lx |= 1
    lx ^= lx
    lx <<= 1
    lx >>= 1
    return lx
end

func body_struct_field(p: Point): int
    var v: int = p.x
    return v
end

func body_two_fields(p: Point): int
    var vx: int = p.x
    var vy: int = p.y
    return vx + vy
end

func body_node_fields(n: Node): int
    var l: int = n.left
    var r: int = n.right
    return l + r
end

func body_person_fields(p: Person): str
    var ag: int = p.age
    var nm: str = p.name
    return nm
end

func body_method_call(o: Obj): int
    var v: int = o.get_value()
    return v
end

func body_two_methods(o: Obj): int
    var va: int = o.get_value()
    var vb: int = o.compare(b: 0)
    return va + vb
end

func body_counter(c: Counter): int
    var g: int = c.get()
    var r: int = c.remaining()
    return g + r
end

func body_list(l: List): int
    var sz: int = l.len()
    var cp: int = l.capacity()
    return sz + cp
end

func body_globals(): int
    var lx: int = x
    var ly: int = y
    return lx + ly
end

func body_consts(): int
    var s: int  = MAX_SIZE
    var d2: int = DEFAULT
    return s + d2
end

func body_global_struct(): int
    var px: int = point.x
    var py: int = point.y
    return px + py
end

func body_global_node(): int
    var l: int = node.left
    var r: int = node.right
    return l + r
end

 

func fact(n: int): int
    return n * fact(n: n - 1)
end

func fib(n: int): int
    return fib(n: n - 1) + fib(n: n - 2)
end

func sum_to(n: int): int
    return n + sum_to(n: n - 1)
end

func power(base: int, exp: int): int
    return base * power(base: base, exp: exp - 1)
end

func gcd(a: int, b: int): int
    return gcd(a: b, b: a % b)
end

func ackermann(m: int, n: int): int
    return ackermann(m: m - 1, n: ackermann(m: m, n: n - 1))
end

 

func call_no_args(): int   return get_zero() end
func call_forward(n: int): int return id_int(n: n) end
func call_chain(a: int, b: int): int return add(a: a, b: b) end

func call_nested(a: int, b: int, c: int): int
    return add(a: add(a: a, b: b), b: c)
end

func call_deep(a: int, b: int, c: int, d: int): int
    return add(a: add(a: a, b: b), b: add(a: c, b: d))
end

func call_method(o: Obj): int       return o.get_value() end
func call_method_b(o: Obj): bool    return o.is_ready() end
func call_counter(c: Counter): int  return c.get() end
func call_list(l: List): int        return l.len() end
func call_stack(s: Stack): int      return s.peek() end

 

public unsafe func mega[A, B, C](
    a: A, b: B, c: C,
    x: int, y: int, z: int,
    p: *int, q: **int,
    flag: bool, s: str, ch: char, f: float
): A
    return a
end

public func ultra[T](
    val: T,
    a: int, b: int, c: int, d: int, e: int,
    flag: bool, s: str
): T
    return val
end

unsafe func raw_mega(
    a: *int, b: **int,
    x: int, y: int, z: int,
    p: int, q: int, r: int
): *int
    return a
end

public func all_types(
    a: int, b: bool, c: char, d: str, e: float,
    f: *int, g: **int,
    h: Point, i: Node, j: Person, k: StatusResult,
    l: Rect, m: Color, n: Range
): int
    return a
end

public unsafe func all_types_generic[A, B, C, D](
    a: A, b: B, c: C, d: D,
    x: int, y: int, z: int,
    p: *int, q: **int,
    flag: bool, s: str, ch: char
): A
    return a
end

public func all_globals_and_consts(): int
    var lx: int  = x + y + z
    var mc: int  = MAX_SIZE + DEFAULT + LIMIT
    var pp: int  = point.x + point.y
    var nn: int  = node.left + node.right
    var ag: int  = person.age
    var gv: float = pi + PI

    return lx + mc + pp + nn + ag
end
const Z_CHAR     = 'z'

const LIMIT: int   = 1000
const SCALE: float = 2.5
const TAG: str     = "tag"
const ENABLED: bool = true

class Counter(start: int)
    var count: int

    func get(): int       return count end
    func is_done(): bool  return count >= start end
    func remaining(): int return start - count end
    func at_zero(): bool  return count == 0 end
    func at_start(): bool return count == start end

    func increment()
        count += 1
    end

    func decrement()
        count -= 1
    end

    func reset()
        count = 0
    end

    func add(n: int)
        count += n
    end

    func sub(n: int)
        count -= n
    end

    func set(n: int)
        count = n
    end

    func compare(n: int): int
        return count - n
    end

    func distance(): int
        return start - count
    end
end

class Obj()
    var value: int
    var active: bool
    var done:   bool
    var valid:  bool

    func is_ready(): bool  return active end
    func get_value(): int  return value end
    func is_valid(): bool  return valid end
    func is_active(): bool return active end
    func is_done(): bool   return done end
    func check(): bool     return valid end
    func get_raw(): int    return value end
    func negate(): int     return -1 * value end

    func compare(b: int): int
        return value - b
    end

    func clamp_val(lo: int, hi: int): int
        return value
    end

    func update(n: int)
        value += n
    end

    func reset()
        value = 0
    end
end

class List()
    var size: int
    var cap:  int

    func len(): int       return size end
    func capacity(): int  return cap end
    func is_empty(): bool return size == 0 end
    func is_full(): bool  return size >= cap end
    func remaining(): int return cap - size end

    func push()
        size += 1
    end

    func pop()
        size -= 1
    end

    func clear()
        size = 0
    end

    func reserve(n: int)
        cap += n
    end
end

class Stack()
    var top:  int
    var size: int

    func peek(): int      return top end
    func len(): int       return size end
    func is_empty(): bool return size == 0 end

    func push(n: int)
        top = n
        size += 1
    end

    func pop(): int
        size -= 1
        return top
    end

    func clear()
        size = 0
        top  = 0
    end
end

class Pair[A, B](a: A, b: B)
    var first:  A
    var second: B

    func get_first(): A     return first end
    func get_second(): B    return second end
    func has_first(): bool  return true end
    func has_second(): bool return true end
end

class Box[T](val: T)
    var inner: T

    func get(): T         return inner end
    func is_set(): bool   return true end

    func set(v: T)
        inner = v
    end
end

class Triple[A, B, C](a: A, b: B, c: C)
    var one:   A
    var two:   B
    var three: C

    func get_one(): A   return one end
    func get_two(): B   return two end
    func get_three(): C return three end
end


 

struct Point:
    x = int
    y = int
end

struct Node:
    left  = int
    right = int
end

struct Person:
    age  = int
    name = str
end

struct StatusResult:
    ok   = bool
    code = int
end

struct Rect:
    x      = int
    y      = int
    width  = int
    height = int
end

struct Color:
    r = int
    g = int
    b = int
end

struct Range:
    lo = int
    hi = int
end

struct Pair:
    first  = int
    second = int
end

struct Triple:
    a = int
    b = int
    c = int
end

struct Vec2:
    x = float
    y = float
end

struct Named:
    name  = str
    value = int
end

struct Tagged:
    tag  = int
    data = int
end

struct Header:
    id   = int
    size = int
    flag = bool
end

 

enum Status:
    Ok(code: int)
    Err(msg: str)
    Pending
end

enum Direction:
    North
    South
    East
    West
end

enum Shape:
    Circle(radius: float)
    Rect(width: float, height: float)
    Point
end

enum Token:
    Int(value: int)
    Float(value: float)
    Str(value: str)
    Bool(value: bool)
    Eof
end

enum Color:
    Red
    Green
    Blue
    Custom(r: int, g: int, b: int)
end

enum Result:
    Ok(value: int)
    Err(code: int, msg: str)
end

enum Option:
    Some(value: int)
    None
end

 

